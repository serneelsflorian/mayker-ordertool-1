# Postgres credentials
POSTGRES_USER=ordertool
POSTGRES_PASSWORD=ordertool
POSTGRES_DB=ordertool

# Connection string used by the backend (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://ordertool:ordertool@localhost:5432/ordertool

# Service ports (host-side)
BACKEND_PORT=8000
FRONTEND_PORT=5173

# Frontend build-time variable (proxied to /api by nginx in Docker; use full URL for local dev without Docker)
VITE_API_BASE_URL=/api

# --- Email / SMTP (Story 6) ---
# Leave SMTP_HOST empty to use the logging sender (logs the email, no delivery).
# Set SMTP_HOST + credentials + EMAIL_FROM to send real mail.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
# Match the mode to the port: starttls (587), tls (465), none (MailHog 1025).
SMTP_TLS_MODE=starttls
EMAIL_FROM=orders@ordertool.demo
